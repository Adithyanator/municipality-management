{
  "name": "kottakkal-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "frontend:dev": "npm run dev --workspace=kottakkal-frontend",
    "backend:dev": "npm run dev --workspace=kottakkal-backend",
    "frontend:build": "npm run build --workspace=kottakkal-frontend",
    "backend:start": "npm run start --workspace=kottakkal-backend",
    "lint": "eslint .",
    "lint:frontend": "eslint frontend",
    "lint:backend": "eslint backend",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.4"
  }
}
