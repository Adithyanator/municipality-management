{
  "name": "kottakkal-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "frontend:dev": "npm run dev --workspace=kottakkal-frontend",
    "backend:dev": "npm run dev --workspace=kottakkal-backend",
    "frontend:build": "npm run build --workspace=kottakkal-frontend",
    "backend:start": "npm run start --workspace=kottakkal-backend",
    "lint": "eslint ."
  }
}
